{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/93a91c37-032c-4380-847c-957c001957ad')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/93a91c37-032c-4380-847c-957c001957ad')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "customDetails": {
          "FailedLogins": "FailedLogins",
          "TimeBucket": "bucket",
          "UserAccount": "SrcUserName"
        },
        "tactics": [
          "CredentialAccess"
        ],
        "status": "Available",
        "queryPeriod": "1h",
        "queryFrequency": "1h",
        "triggerThreshold": 0,
        "entityMappings": [
          {
            "entityType": "Account",
            "fieldMappings": [
              {
                "identifier": "FullName",
                "columnName": "AccountCustomEntity"
              }
            ]
          }
        ],
        "query": "let threshold = 10;\nSlackAudit\n| where DvcAction in~ ('user_login_failed')\n| summarize FailedLogins = count() by SrcUserName, bucket = bin(TimeGenerated, 5m)\n| where FailedLogins > threshold\n| extend AccountCustomEntity = SrcUserName\n| project SrcUserName, bucket, FailedLogins, AccountCustomEntity\n",
        "name": "SlackAudit - Multiple failed logins for user",
        "severity": "Medium",
        "description": "'Identifies multiple failed Slack logins for a user account within a short time window, which may indicate password\nguessing or brute-force activity.'\n",
        "triggerOperator": "gt"
      }
    }
  ]
}
