{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/9265ae4d-6bb0-4c18-961d-f7aae67d1546')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/9265ae4d-6bb0-4c18-961d-f7aae67d1546')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "queryFrequency": "1h",
        "name": "Flare marketplace results",
        "queryPeriod": "1h",
        "query": "FireworkV2_CL\n| where notempty(uid) and RiskScore >= 3\n| extend index_name = split(uid, \"/\")[0]\n| where index_name == \"listing\"\n",
        "status": "Available",
        "severity": "Medium",
        "triggerThreshold": 0,
        "triggerOperator": "gt",
        "description": "'This query searches for underground markets and shops where illicit goods and services are bought and sold.'\n",
        "tactics": [
          "Reconnaissance"
        ]
      }
    }
  ]
}
