{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/9b784b65-2d16-4c9f-9f59-2a5d4c659f42')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/9b784b65-2d16-4c9f-9f59-2a5d4c659f42')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "queryPeriod": "5m",
        "tactics": [
          "Exfiltration"
        ],
        "incidentConfiguration": {
          "groupingConfiguration": {
            "enabled": false,
            "matchingMethod": "AllEntities",
            "lookbackDuration": "PT1H",
            "reopenClosedIncident": false
          },
          "createIncident": true
        },
        "name": "Filewall - Blocked emails",
        "queryFrequency": "5m",
        "eventGroupingSettings": {
          "aggregationKind": "AlertPerResult"
        },
        "entityMappings": [
          {
            "entityType": "Account",
            "fieldMappings": [
              {
                "identifier": "FullName",
                "columnName": "ActorUsername"
              }
            ]
          },
          {
            "entityType": "MailMessage",
            "fieldMappings": [
              {
                "identifier": "Recipient",
                "columnName": "EmailRecipientTo"
              },
              {
                "identifier": "Subject",
                "columnName": "EmailSubject"
              },
              {
                "identifier": "Sender",
                "columnName": "EmailSenderFrom"
              }
            ]
          }
        ],
        "description": "Identifies emails blocked by Filewall for Microsoft 365 (Exchange).",
        "triggerThreshold": 0,
        "triggerOperator": "gt",
        "status": "Available",
        "query": "FilewallM365ExchangeEvent()\n| where EventVendor == 'ODI-X' and EventProduct == 'Filewall for Microsoft 365'\n| where EventType == 'ThreatInfo' and EventResult == 'Blocked'\n",
        "severity": "High"
      }
    }
  ]
}
