{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/8d2b6f4c-1a37-4e9b-b5c8-7f0e3a2d9c14')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/8d2b6f4c-1a37-4e9b-b5c8-7f0e3a2d9c14')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "customDetails": {
          "Environment": "Environment",
          "PolicyName": "PolicyName",
          "IssueStatus": "IssueStatus",
          "RemediationSteps": "RemediationSteps",
          "PolicyCategories": "PolicyCategories",
          "AffectedSystems": "AffectedSystems"
        },
        "tactics": [
          "Impact"
        ],
        "status": "Available",
        "queryPeriod": "1d",
        "queryFrequency": "1d",
        "incidentConfiguration": {
          "groupingConfiguration": {
            "reopenClosedIncident": false,
            "matchingMethod": "AllEntities",
            "enabled": false,
            "lookbackDuration": "PT5H"
          },
          "createIncident": true
        },
        "eventGroupingSettings": {
          "aggregationKind": "AlertPerResult"
        },
        "triggerThreshold": 0,
        "entityMappings": [
          {
            "entityType": "Host",
            "fieldMappings": [
              {
                "identifier": "HostName",
                "columnName": "ResourceDisplayId"
              }
            ]
          },
          {
            "entityType": "AzureResource",
            "fieldMappings": [
              {
                "identifier": "ResourceId",
                "columnName": "ResourceDisplayId"
              }
            ]
          }
        ],
        "query": "GambitPoliciesIssues\n| where State == \"Active\" and Severity == \"High\"\n",
        "name": "Gambit Security - Critical Policy Issue Promotion",
        "severity": "High",
        "description": "'Creates an incident when Gambit Security reports an Active, High-severity policy issue in Microsoft Sentinel.'\n",
        "triggerOperator": "gt"
      }
    }
  ]
}
