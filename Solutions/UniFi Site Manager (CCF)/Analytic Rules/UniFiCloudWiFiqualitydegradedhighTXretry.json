{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/f5130582-9e0e-cb47-af0b-dcd8b261fa04')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/f5130582-9e0e-cb47-af0b-dcd8b261fa04')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "tactics": [
          "Impact"
        ],
        "incidentConfiguration": {
          "createIncident": true,
          "groupingConfiguration": {
            "enabled": true,
            "reopenClosedIncident": false,
            "lookbackDuration": "PT5H",
            "matchingMethod": "AllEntities"
          }
        },
        "triggerThreshold": 0,
        "query": "Unifi_SiteManager_Sites_CL\n      | where TimeGenerated > ago(1h)\n| extend txRetry = WifiTxRetryPct\n      | where txRetry > 5.0\n      | summarize arg_max(TimeGenerated, *) by SiteId, SiteName\n      | extend Activity = strcat('TX retry rate ', round(txRetry, 1), '% (>5% threshold)')\n      | project TimeGenerated, SiteId, SiteName, Activity, TxRetryPct = round(txRetry, 1)\n",
        "queryPeriod": "1h",
        "subTechniques": [
          "T1498.001"
        ],
        "triggerOperator": "gt",
        "entityMappings": [
          {
            "fieldMappings": [
              {
                "identifier": "HostName",
                "columnName": "SiteId"
              },
              {
                "identifier": "DnsDomain",
                "columnName": "SiteName"
              }
            ],
            "entityType": "Host"
          }
        ],
        "description": "Identifies when the site-wide WiFi TX retry rate exceeds 5 percent, which may indicate RF interference, channel congestion, or active wireless attack.\n",
        "name": "UniFi Site Manager: WiFi quality degraded (high TX retry)",
        "status": "Available",
        "severity": "Low",
        "queryFrequency": "1h"
      }
    }
  ]
}
