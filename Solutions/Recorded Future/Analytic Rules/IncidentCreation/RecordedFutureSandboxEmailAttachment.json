{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/a1b2c3d4-5678-90ab-cdef-222222222222')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/a1b2c3d4-5678-90ab-cdef-222222222222')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "query": "RecordedFutureSandboxResults_CL\n| where TimeGenerated >= now(-1h)\n| where Source_s == \"OutlookAttachment\"\n| where toint(SandboxScore_s) >= 50\n",
        "entityMappings": [
          {
            "fieldMappings": [
              {
                "columnName": "FileName_s",
                "identifier": "Name"
              }
            ],
            "entityType": "File"
          },
          {
            "fieldMappings": [
              {
                "columnName": "EmailFrom_s",
                "identifier": "MailboxPrimaryAddress"
              }
            ],
            "entityType": "Mailbox"
          }
        ],
        "triggerThreshold": 0,
        "triggerOperator": "gt",
        "tactics": [],
        "queryFrequency": "1h",
        "status": "Available",
        "incidentConfiguration": {
          "createIncident": true,
          "groupingConfiguration": {
            "lookbackDuration": "1h",
            "reopenClosedIncident": false,
            "matchingMethod": "Selected",
            "enabled": true,
            "groupByCustomDetails": [
              "EmailFrom"
            ]
          }
        },
        "severity": "High",
        "alertDetailsOverride": {
          "alertDescriptionFormat": "_Recorded Future Sandbox - Malicious Email Attachment Detected_\n\n**Sandbox Score:** {{SandboxScore_s}}/100\n\n**Verdict:** {{SandboxVerdict_s}}\n\n**Sample ID:** {{SampleId_s}}\n\nA malicious file was detected in an email attachment. Review the full sandbox report and investigate the sender.\n",
          "alertDisplayNameFormat": "Malicious Email Attachment: {{FileName_s}} from {{EmailFrom_s}}"
        },
        "name": "Recorded Future Sandbox - Malicious Email Attachment",
        "customDetails": {
          "SampleId": "SampleId_s",
          "EmailFrom": "EmailFrom_s",
          "SandboxVerdict": "SandboxVerdict_s",
          "Source": "Source_s",
          "EmailTo": "EmailTo_s",
          "RFLabel": "SourceSystem",
          "FileName": "FileName_s",
          "SandboxScore": "SandboxScore_s"
        },
        "eventGroupingSettings": {
          "aggregationKind": "AlertPerResult"
        },
        "description": "'Creates incidents when Recorded Future Sandbox detects malicious files from Outlook email attachments'\n",
        "queryPeriod": "1h"
      }
    }
  ]
}
