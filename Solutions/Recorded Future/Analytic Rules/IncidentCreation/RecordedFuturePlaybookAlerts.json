{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/0aded97e-4e2d-4e4d-93cf-4a7e45c7bab2')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/0aded97e-4e2d-4e4d-93cf-4a7e45c7bab2')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "eventGroupingSettings": {
          "aggregationKind": "AlertPerResult"
        },
        "status": "Available",
        "query": "RecordedFuturePlaybookAlerts_CL\n| where TimeGenerated >= now(-1h)\n",
        "triggerThreshold": 0,
        "tactics": [],
        "customDetails": {
          "Category": "Category",
          "RFLabel": "SourceSystem"
        },
        "queryFrequency": "1h",
        "alertDetailsOverride": {
          "alertDynamicProperties": [
            {
              "alertProperty": "AlertLink",
              "value": "link_s"
            }
          ],
          "alertDescriptionFormat": "_Recorded Future Alert_\n\nEvidence Summary:\n{{alert_description}}\n\nPriority: {{priority_s}}\n\nRecorded Future Playbook Alert ID\n{{id_s}}\n",
          "alertDisplayNameFormat": "Alert: {{rule_label_s}}  - {{title_s}}"
        },
        "name": "Recorded Future Playbook Alerts Incident Creation",
        "severity": "Medium",
        "triggerOperator": "gt",
        "incidentConfiguration": {
          "groupingConfiguration": {
            "matchingMethod": "Selected",
            "lookbackDuration": "1h",
            "reopenClosedIncident": false,
            "enabled": true,
            "groupByCustomDetails": [
              "Category"
            ]
          },
          "createIncident": true
        },
        "queryPeriod": "1h",
        "description": "'Create Recorded Future Playbook Alerts in Microsoft Defender'\n"
      }
    }
  ]
}
