{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/a1b2c3d4-5678-90ab-cdef-333333333333')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/a1b2c3d4-5678-90ab-cdef-333333333333')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "incidentConfiguration": {
          "groupingConfiguration": {
            "reopenClosedIncident": false,
            "groupByCustomDetails": [
              "SandboxVerdict"
            ],
            "lookbackDuration": "1h",
            "matchingMethod": "Selected",
            "enabled": true
          },
          "createIncident": true
        },
        "triggerOperator": "gt",
        "description": "'Creates incidents when Recorded Future Sandbox detects malicious files from Azure Storage Account'\n",
        "name": "Recorded Future Sandbox - Malicious File in Storage Account",
        "queryPeriod": "1h",
        "queryFrequency": "1h",
        "triggerThreshold": 0,
        "alertDetailsOverride": {
          "alertDisplayNameFormat": "Malicious File in Storage: {{FileName_s}}",
          "alertDescriptionFormat": "_Recorded Future Sandbox - Malicious File in Storage Account_\n\n**Sandbox Score:** {{SandboxScore_s}}/100\n\n**Verdict:** {{SandboxVerdict_s}}\n\n**Sample ID:** {{SampleId_s}}\n\nA malicious file was detected in an Azure Storage Account. Investigate the source of this file and review the full sandbox report.\n"
        },
        "customDetails": {
          "SandboxScore": "SandboxScore_s",
          "SampleId": "SampleId_s",
          "Source": "Source_s",
          "FileName": "FileName_s",
          "SandboxVerdict": "SandboxVerdict_s",
          "RFLabel": "SourceSystem"
        },
        "severity": "Medium",
        "query": "RecordedFutureSandboxResults_CL\n| where TimeGenerated >= now(-1h)\n| where Source_s == \"StorageAccount\"\n| where toint(SandboxScore_s) >= 50\n",
        "status": "Available",
        "entityMappings": [
          {
            "fieldMappings": [
              {
                "identifier": "Name",
                "columnName": "FileName_s"
              }
            ],
            "entityType": "File"
          }
        ],
        "eventGroupingSettings": {
          "aggregationKind": "AlertPerResult"
        },
        "tactics": []
      }
    }
  ]
}
