{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/0aded97e-4e2d-4e4d-93cf-4a7e45c7bab3')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/0aded97e-4e2d-4e4d-93cf-4a7e45c7bab3')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "query": "RecordedFuturePortalAlerts_CL\n| where TimeGenerated >= now(-1h)\n",
        "triggerThreshold": 0,
        "triggerOperator": "gt",
        "tactics": [],
        "queryFrequency": "1h",
        "status": "Available",
        "incidentConfiguration": {
          "createIncident": true,
          "groupingConfiguration": {
            "lookbackDuration": "1h",
            "reopenClosedIncident": false,
            "matchingMethod": "Selected",
            "enabled": true,
            "groupByCustomDetails": [
              "RuleId"
            ]
          }
        },
        "severity": "Medium",
        "alertDetailsOverride": {
          "alertDescriptionFormat": "_Recorded Future Alert_\n\nAlertID:\n{{AlertID_s}}\n\nTriggered: {{Triggered_t}}\n\nAI Summary: {{AISummary_s}}\n",
          "alertDisplayNameFormat": "Alert: {{AlertName_s}}",
          "alertDynamicProperties": [
            {
              "value": "URL_s",
              "alertProperty": "AlertLink"
            }
          ]
        },
        "name": "Recorded Future Alerts Incident Creation",
        "customDetails": {
          "RuleId": "RuleId_s",
          "RuleName": "RuleName_s",
          "RFLabel": "SourceSystem"
        },
        "eventGroupingSettings": {
          "aggregationKind": "AlertPerResult"
        },
        "description": "'Create Recorded Future Alerts in Microsoft Defender'\n",
        "queryPeriod": "1h"
      }
    }
  ]
}
