{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/2a3b4c5d-6e7f-4a0b-8c1d-2e3f4a5b6c74')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/2a3b4c5d-6e7f-4a0b-8c1d-2e3f4a5b6c74')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "severity": "High",
        "description": "Detects changes to SAP user master data (SU01), forwarded by Pathlock Threat Detection and Response. User master data modifications include password changes, account locking/unlocking, validity date changes, and group assignments - any of which can be used to create persistent unauthorized access or facilitate account takeover.",
        "tactics": [
          "Persistence",
          "PrivilegeEscalation"
        ],
        "triggerOperator": "gt",
        "queryPeriod": "1h",
        "incidentConfiguration": {
          "createIncident": true,
          "groupingConfiguration": {
            "groupByCustomDetails": [],
            "reopenClosedIncident": false,
            "groupByEntities": [],
            "lookbackDuration": "5h",
            "matchingMethod": "AnyAlert",
            "groupByAlertDetails": [],
            "enabled": true
          }
        },
        "suppressionEnabled": false,
        "eventGroupingSettings": {
          "aggregationKind": "SingleAlert"
        },
        "name": "Pathlock TDnR - User Master Data Changes",
        "entityMappings": [
          {
            "fieldMappings": [
              {
                "identifier": "Name",
                "columnName": "Bname"
              }
            ],
            "entityType": "Account"
          },
          {
            "fieldMappings": [
              {
                "identifier": "HostName",
                "columnName": "Hostname"
              }
            ],
            "entityType": "Host"
          },
          {
            "fieldMappings": [
              {
                "identifier": "Address",
                "columnName": "SrcIp"
              }
            ],
            "entityType": "IP"
          }
        ],
        "suppressionDuration": "5h",
        "queryFrequency": "1h",
        "triggerThreshold": 0,
        "query": "Pathlock_TDnR_CL\n| where DataSource == \"USER_MASTER_CHANGES\"\n| project TimeGenerated, Sysid, DataSource, Eventid, Instance, Hostname, Bname,\n          Tcode, Report, Area, Subid, SrcIp, DestIp, AffectedUser, LogLine,\n          MsgType, MsgId, MsgNo, MessageV1, MessageV2, MessageV3, MessageV4, CentralTs\n",
        "status": "Available"
      }
    }
  ]
}
