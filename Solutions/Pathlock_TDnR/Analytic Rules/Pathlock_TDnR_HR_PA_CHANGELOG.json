{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/2a3b4c5d-6e7f-4a0b-8c1d-2e3f4a5b6c30')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/2a3b4c5d-6e7f-4a0b-8c1d-2e3f4a5b6c30')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "suppressionEnabled": false,
        "eventGroupingSettings": {
          "aggregationKind": "SingleAlert"
        },
        "suppressionDuration": "5h",
        "queryFrequency": "1h",
        "tactics": [
          "Impact",
          "Collection"
        ],
        "queryPeriod": "1h",
        "incidentConfiguration": {
          "createIncident": true,
          "groupingConfiguration": {
            "enabled": true,
            "matchingMethod": "AnyAlert",
            "groupByEntities": [],
            "reopenClosedIncident": false,
            "lookbackDuration": "5h",
            "groupByCustomDetails": [],
            "groupByAlertDetails": []
          }
        },
        "description": "Detects change requests to the HR user master data in SAP, forwarded by Pathlock Threat Detection and Response. Unauthorized HR data changes may indicate targeted manipulation of employee records, payroll fraud, or exfiltration of sensitive personnel information.",
        "name": "Pathlock TDnR - HR User Master Change Requests",
        "triggerOperator": "gt",
        "status": "Available",
        "triggerThreshold": 0,
        "entityMappings": [
          {
            "entityType": "Account",
            "fieldMappings": [
              {
                "identifier": "Name",
                "columnName": "Bname"
              }
            ]
          },
          {
            "entityType": "Host",
            "fieldMappings": [
              {
                "identifier": "HostName",
                "columnName": "Hostname"
              }
            ]
          },
          {
            "entityType": "IP",
            "fieldMappings": [
              {
                "identifier": "Address",
                "columnName": "SrcIp"
              }
            ]
          }
        ],
        "query": "Pathlock_TDnR_CL\n| where DataSource == \"HR_PA_CHANGELOG\"\n| project TimeGenerated, Sysid, DataSource, Eventid, Instance, Hostname, Bname,\n          Tcode, Report, Area, Subid, SrcIp, DestIp, AffectedUser, LogLine,\n          MsgType, MsgId, MsgNo, MessageV1, MessageV2, MessageV3, MessageV4, CentralTs\n",
        "severity": "Medium"
      }
    }
  ]
}
