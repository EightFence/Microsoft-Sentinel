{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/2a3b4c5d-6e7f-4a0b-8c1d-2e3f4a5b6c24')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/2a3b4c5d-6e7f-4a0b-8c1d-2e3f4a5b6c24')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "query": "Pathlock_TDnR_CL\n| where DataSource == \"FILE_CHECKSUM\"\n| project TimeGenerated, Sysid, DataSource, Eventid, Instance, Hostname, Bname,\n          Tcode, Report, Area, Subid, SrcIp, DestIp, AffectedUser, LogLine,\n          MsgType, MsgId, MsgNo, MessageV1, MessageV2, MessageV3, MessageV4, CentralTs\n",
        "suppressionDuration": "5h",
        "entityMappings": [
          {
            "fieldMappings": [
              {
                "columnName": "Bname",
                "identifier": "Name"
              }
            ],
            "entityType": "Account"
          },
          {
            "fieldMappings": [
              {
                "columnName": "Hostname",
                "identifier": "HostName"
              }
            ],
            "entityType": "Host"
          },
          {
            "fieldMappings": [
              {
                "columnName": "SrcIp",
                "identifier": "Address"
              }
            ],
            "entityType": "IP"
          }
        ],
        "triggerThreshold": 0,
        "triggerOperator": "gt",
        "tactics": [
          "DefenseEvasion",
          "Persistence"
        ],
        "queryFrequency": "1h",
        "status": "Available",
        "incidentConfiguration": {
          "createIncident": true,
          "groupingConfiguration": {
            "groupByEntities": [],
            "enabled": true,
            "groupByAlertDetails": [],
            "lookbackDuration": "5h",
            "groupByCustomDetails": [],
            "matchingMethod": "AnyAlert",
            "reopenClosedIncident": false
          }
        },
        "severity": "High",
        "name": "Pathlock TDnR - Critical File Integrity Changes",
        "suppressionEnabled": false,
        "eventGroupingSettings": {
          "aggregationKind": "SingleAlert"
        },
        "description": "Detects changes to checksums of critical SAP files, forwarded by Pathlock Threat Detection and Response. File integrity violations may indicate malware installation, unauthorized patching, or tampering with SAP executables and configuration files.",
        "queryPeriod": "1h"
      }
    }
  ]
}
