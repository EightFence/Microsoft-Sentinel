{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/2a3b4c5d-6e7f-4a0b-8c1d-2e3f4a5b6c10')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/2a3b4c5d-6e7f-4a0b-8c1d-2e3f4a5b6c10')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "tactics": [
          "PrivilegeEscalation"
        ],
        "status": "Available",
        "queryPeriod": "1h",
        "queryFrequency": "1h",
        "incidentConfiguration": {
          "groupingConfiguration": {
            "lookbackDuration": "5h",
            "groupByCustomDetails": [],
            "reopenClosedIncident": false,
            "matchingMethod": "AnyAlert",
            "enabled": true,
            "groupByAlertDetails": [],
            "groupByEntities": []
          },
          "createIncident": true
        },
        "suppressionEnabled": false,
        "eventGroupingSettings": {
          "aggregationKind": "SingleAlert"
        },
        "suppressionDuration": "5h",
        "triggerThreshold": 0,
        "query": "Pathlock_TDnR_CL\n| where DataSource == \"CHANGEDOC_GRAC\"\n| project TimeGenerated, Sysid, DataSource, Eventid, Instance, Hostname, Bname,\n          Tcode, Report, Area, Subid, SrcIp, DestIp, AffectedUser, LogLine,\n          MsgType, MsgId, MsgNo, MessageV1, MessageV2, MessageV3, MessageV4, CentralTs\n",
        "name": "Pathlock TDnR - GRC Access Control Change Documents",
        "severity": "Medium",
        "entityMappings": [
          {
            "entityType": "Account",
            "fieldMappings": [
              {
                "identifier": "Name",
                "columnName": "Bname"
              }
            ]
          },
          {
            "entityType": "Host",
            "fieldMappings": [
              {
                "identifier": "HostName",
                "columnName": "Hostname"
              }
            ]
          },
          {
            "entityType": "IP",
            "fieldMappings": [
              {
                "identifier": "Address",
                "columnName": "SrcIp"
              }
            ]
          }
        ],
        "description": "Detects changes to SAP GRC (Governance, Risk, and Compliance) access control configuration, forwarded by Pathlock Threat Detection and Response. Modifications to GRC settings may indicate attempts to bypass segregation of duties controls or disable risk monitoring.",
        "triggerOperator": "gt"
      }
    }
  ]
}
