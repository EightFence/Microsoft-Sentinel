{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/2a3b4c5d-6e7f-4a0b-8c1d-2e3f4a5b6c29')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/2a3b4c5d-6e7f-4a0b-8c1d-2e3f4a5b6c29')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "severity": "Medium",
        "queryPeriod": "1h",
        "query": "Pathlock_TDnR_CL\n| where DataSource == \"HANA_PARAM_CHANGED\"\n| project TimeGenerated, Sysid, DataSource, Eventid, Instance, Hostname, Bname,\n          Tcode, Report, Area, Subid, SrcIp, DestIp, AffectedUser, LogLine,\n          MsgType, MsgId, MsgNo, MessageV1, MessageV2, MessageV3, MessageV4, CentralTs\n",
        "suppressionDuration": "5h",
        "queryFrequency": "1h",
        "description": "Detects changes to SAP HANA database configuration parameters, forwarded by Pathlock Threat Detection and Response. Unauthorized HANA parameter modifications may be used to disable security controls, weaken audit logging, or alter database behavior to facilitate attacks.",
        "incidentConfiguration": {
          "createIncident": true,
          "groupingConfiguration": {
            "groupByAlertDetails": [],
            "reopenClosedIncident": false,
            "matchingMethod": "AnyAlert",
            "groupByEntities": [],
            "lookbackDuration": "5h",
            "enabled": true,
            "groupByCustomDetails": []
          }
        },
        "name": "Pathlock TDnR - SAP HANA Parameter Changes",
        "triggerThreshold": 0,
        "tactics": [
          "DefenseEvasion"
        ],
        "status": "Available",
        "suppressionEnabled": false,
        "entityMappings": [
          {
            "entityType": "Account",
            "fieldMappings": [
              {
                "columnName": "Bname",
                "identifier": "Name"
              }
            ]
          },
          {
            "entityType": "Host",
            "fieldMappings": [
              {
                "columnName": "Hostname",
                "identifier": "HostName"
              }
            ]
          },
          {
            "entityType": "IP",
            "fieldMappings": [
              {
                "columnName": "SrcIp",
                "identifier": "Address"
              }
            ]
          }
        ],
        "triggerOperator": "gt",
        "eventGroupingSettings": {
          "aggregationKind": "SingleAlert"
        }
      }
    }
  ]
}
