{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/2a3b4c5d-6e7f-4a0b-8c1d-2e3f4a5b6c59')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/2a3b4c5d-6e7f-4a0b-8c1d-2e3f4a5b6c59')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "eventGroupingSettings": {
          "aggregationKind": "SingleAlert"
        },
        "suppressionDuration": "5h",
        "queryPeriod": "1h",
        "query": "Pathlock_TDnR_CL\n| where DataSource == \"SLG1_ODATA\"\n| project TimeGenerated, Sysid, DataSource, Eventid, Instance, Hostname, Bname,\n          Tcode, Report, Area, Subid, SrcIp, DestIp, AffectedUser, LogLine,\n          MsgType, MsgId, MsgNo, MessageV1, MessageV2, MessageV3, MessageV4, CentralTs\n",
        "triggerThreshold": 0,
        "tactics": [
          "Collection",
          "Exfiltration"
        ],
        "queryFrequency": "1h",
        "status": "Available",
        "name": "Pathlock TDnR - OData Application Log Events",
        "severity": "Medium",
        "suppressionEnabled": false,
        "triggerOperator": "gt",
        "incidentConfiguration": {
          "groupingConfiguration": {
            "groupByAlertDetails": [],
            "lookbackDuration": "5h",
            "reopenClosedIncident": false,
            "groupByEntities": [],
            "matchingMethod": "AnyAlert",
            "groupByCustomDetails": [],
            "enabled": true
          },
          "createIncident": true
        },
        "entityMappings": [
          {
            "entityType": "Account",
            "fieldMappings": [
              {
                "columnName": "Bname",
                "identifier": "Name"
              }
            ]
          },
          {
            "entityType": "Host",
            "fieldMappings": [
              {
                "columnName": "Hostname",
                "identifier": "HostName"
              }
            ]
          },
          {
            "entityType": "IP",
            "fieldMappings": [
              {
                "columnName": "SrcIp",
                "identifier": "Address"
              }
            ]
          }
        ],
        "description": "Detects security events from SAP OData service application logs (SLG1), forwarded by Pathlock Threat Detection and Response. OData anomalies may indicate API abuse, unauthorized mass data extraction via OData endpoints, or exploitation of SAP Fiori and S/4HANA OData services."
      }
    }
  ]
}
