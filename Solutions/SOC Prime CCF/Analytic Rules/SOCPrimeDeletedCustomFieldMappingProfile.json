{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/a1b2c3d4-e5f6-4078-9012-3456789abcde')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/a1b2c3d4-e5f6-4078-9012-3456789abcde')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "query": "SOCPrimeAuditLogs_CL\n| where EventName == \"Deleted a Custom Field Mapping profile\"\n| project TimeGenerated, EventName, UserEmail, UserName, SourceIp, Uri, Type\n",
        "name": "Deleted a Custom Field Mapping profile",
        "triggerOperator": "gt",
        "severity": "Medium",
        "queryFrequency": "1h",
        "entityMappings": [
          {
            "fieldMappings": [
              {
                "columnName": "UserName",
                "identifier": "Name"
              }
            ],
            "entityType": "Account"
          },
          {
            "fieldMappings": [
              {
                "columnName": "SourceIp",
                "identifier": "Address"
              }
            ],
            "entityType": "IP"
          }
        ],
        "queryPeriod": "1h",
        "tactics": [
          "DefenseEvasion"
        ],
        "description": "'Deleted a Custom Field Mapping profile from SOC Prime platform'\n",
        "status": "Available",
        "triggerThreshold": 0
      }
    }
  ]
}
