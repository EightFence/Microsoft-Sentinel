{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/b808063b-07d5-432c-95d0-8900da61cce9')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/b808063b-07d5-432c-95d0-8900da61cce9')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "customDetails": null,
        "eventGroupingSettings": {
          "aggregationKind": "SingleAlert"
        },
        "description": "'42Crunch API protection against rate limiting'\n",
        "entityMappings": [
          {
            "fieldMappings": [
              {
                "columnName": "SourceIp",
                "identifier": "Address"
              }
            ],
            "entityType": "IP"
          },
          {
            "fieldMappings": [
              {
                "columnName": "Hostname",
                "identifier": "HostName"
              }
            ],
            "entityType": "Host"
          },
          {
            "fieldMappings": [
              {
                "columnName": "InstanceName",
                "identifier": "FullName"
              }
            ],
            "entityType": "Account"
          }
        ],
        "name": "API - Rate limiting",
        "queryFrequency": "5m",
        "queryPeriod": "5m",
        "tactics": [
          "Impact"
        ],
        "triggerOperator": "gt",
        "query": "let firstRec = FortyTwoCrunchAPIProtection\n| where TimeGenerated >= ago(5m) \n| project-away NonBlockingMode, SourcePort, DestinationPort, Query, ApiId, RequestHeader, ResponseHeader, Errors, EventType, Uuid\n| where UriPath has \"/api/login\" and Status == 429;\nlet rateLimitCount = (toscalar(firstRec | count));\nlet recCount = iff((rateLimitCount > 20), 1, 0);\nfirstRec | top recCount by Timestamp desc;\n",
        "severity": "Medium",
        "triggerThreshold": 0,
        "status": "Available"
      }
    }
  ]
}
