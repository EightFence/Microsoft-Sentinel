{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "Parameters": {
    "Workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/d944d564-b6fa-470d-b5ab-41b341878c5e')]",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/d944d564-b6fa-470d-b5ab-41b341878c5e')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "kind": "Scheduled",
      "apiVersion": "2021-03-01-preview",
      "properties": {
        "queryFrequency": "5m",
        "entityMappings": [
          {
            "fieldMappings": [
              {
                "identifier": "Address",
                "columnName": "SourceIp"
              }
            ],
            "entityType": "IP"
          },
          {
            "fieldMappings": [
              {
                "identifier": "HostName",
                "columnName": "Hostname"
              }
            ],
            "entityType": "Host"
          },
          {
            "fieldMappings": [
              {
                "identifier": "FullName",
                "columnName": "InstanceName"
              }
            ],
            "entityType": "Account"
          }
        ],
        "severity": "High",
        "status": "Available",
        "eventGroupingSettings": {
          "aggregationKind": "SingleAlert"
        },
        "description": "'42Crunch API protection against API scraping'\n",
        "triggerOperator": "gt",
        "customDetails": null,
        "triggerThreshold": 0,
        "name": "API - API Scraping",
        "queryPeriod": "5m",
        "tactics": [
          "Reconnaissance",
          "Collection"
        ],
        "query": "let firstRec = FortyTwoCrunchAPIProtection\n| where TimeGenerated >= ago(5m) \n| project-away NonBlockingMode, SourcePort, DestinationPort, Query, ApiId, RequestHeader, ResponseHeader, Errors, EventType, Uuid\n| where UriPath has \"/api/properties?page=\" and Status == 200;\nlet rateLimitCount = (toscalar(firstRec | count));\nlet recCount = iff((rateLimitCount > 100), 1, 0);\nfirstRec | top recCount by Timestamp desc;\n"
      }
    }
  ]
}
